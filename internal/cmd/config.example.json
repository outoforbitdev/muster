{
  "stacks": {
    "muster-workflows": {
      "repos": [
        {
          "url": "https://github.com/outoforbitdev/muster",
          "templateBranchSyntax": "feature-{workspace}",
          "description": "Workspace orchestration CLI"
        },
        {
          "url": "https://github.com/outoforbitdev/reusable-workflows-library",
          "templateBranchSyntax": "feature-{workspace}",
          "description": "Shared GitHub Actions workflows"
        }
      ],
      "description": "Muster CLI and shared workflow automation. Use for workspace orchestration and CI/CD workflow development."
    }
  },
  "defaults": {
    "checkoutBranchOnLaunch": true,
    "templateBranchSyntax": "feature-{workspace}",
    "agentCommand": "claude --name {workspace}",
    "editorCommand": "code {workspaceDirectory}",
    "launchAgent": true,
    "launchEditor": false
  }
}
